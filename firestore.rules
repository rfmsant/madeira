rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App privada para 2 pessoas (Rui + Catarina) via Anonymous Auth.
    // Qualquer utilizador autenticado (anónimo) pode ler/escrever a viagem.
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
